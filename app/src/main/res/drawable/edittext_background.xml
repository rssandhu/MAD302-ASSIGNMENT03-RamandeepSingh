<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Background color -->
    <solid android:color="#FFFFFF" />

    <!-- 2dp rounded corners -->
    <corners android:radius="12dp" />

    <!-- 1dp stroke border -->
    <stroke
        android:width="1dp"
        android:color="#DDDDDD" />

    <!-- 8dp padding inside -->
    <padding
        android:left="12dp"
        android:top="12dp"
        android:right="12dp"
        android:bottom="12dp" />

</shape>